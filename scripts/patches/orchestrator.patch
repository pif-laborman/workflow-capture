+
+async def _upload_to_supabase_storage(
+    image_bytes: bytes,
+    object_path: str,
+    content_type: str = "image/png",
+) -> str | None:
+    """Upload bytes to the Supabase Storage 'media' bucket (fire-and-forget).
+
+    Returns the object path on success, None on failure.
+    """
+    import os
+
+    import httpx
+
+    supabase_url = os.environ.get("PIF_SUPABASE_URL")
+    supabase_key = os.environ.get("PIF_SUPABASE_ANON_KEY")
+
+    if not supabase_url or not supabase_key:
+        logger.warning("Supabase credentials not set, skipping photo upload")
+        return None
+
+    url = f"{supabase_url}/storage/v1/object/media/{object_path}"
+    headers = {
+        "Authorization": f"Bearer {supabase_key}",
+        "apikey": supabase_key,
+        "Content-Type": content_type,
+    }
+
+    try:
+        async with httpx.AsyncClient(timeout=30.0) as client:
+            resp = await client.post(url, content=image_bytes, headers=headers)
+            if resp.status_code in (200, 201):
+                logger.info("Uploaded photo to Supabase Storage", path=object_path)
+                return object_path
+            else:
+                logger.warning(
+                    "Supabase Storage upload failed",
+                    status=resp.status_code,
+                    body=resp.text[:200],
+                )
+                return None
+    except Exception as e:
+        logger.warning("Supabase Storage upload error", error=str(e))
+        return None
+
